---
import Layout from '../layouts/Layout.astro';
import H1bDatabase from '../components/H1bDatabase';
---

<Layout title="H1B Sponsor DB | SuperSearch">
  <main class="relative z-10 max-w-7xl mx-auto p-4 md:p-8 space-y-8">
    <header class="flex justify-between items-end border-b border-zinc-800 pb-4">
      <div>
        <h1 class="text-2xl font-black tracking-tighter text-white">H1B_SPONSOR_INDEX <span class="text-green-500 text-xs">Offline Archive</span></h1>
        <p class="text-[10px] text-zinc-500 uppercase">Static Snapshot of 2,200+ Verified US Tech Entities</p>
      </div>
    </header>

    <div class="mt-8">
      <H1bDatabase client:load />
    </div>
  </main>
</Layout>
